:{$PORT} {
	root * /app/dist
	file_server

	# No cache for HTML pages
	@html path *.html /
	header @html Cache-Control "no-cache, no-store, must-revalidate"
	header @html Pragma "no-cache"
	header @html Expires "0"

	# Cache static assets for 1 year (Vite hashed filenames)
	@static path /assets/*
	header @static Cache-Control "public, max-age=31536000, immutable"

	# Cache images/fonts in public folder for 30 days
	@publicAssets path *.png *.jpg *.jpeg *.webp *.svg *.ico *.woff *.woff2
	header @publicAssets Cache-Control "public, max-age=2592000"

	# SPA fallback
	try_files {path} /index.html

	# Compression
	encode gzip zstd
}
